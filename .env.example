# Azure Speech Service
AZURE_SPEECH_KEY=dein-key-hier
AZURE_SPEECH_REGION=westeurope

# Whisper (Fallback wenn Azure nicht konfiguriert)
WHISPER_CMD=whisper
WHISPER_MODEL_RT=small
WHISPER_MODEL_FIN=large-v3

# E-Mail (SMTP) – z.B. Microsoft 365 / Outlook
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=deine-email@firma.de
SMTP_PASS=dein-passwort-oder-app-password
SMTP_FROM=deine-email@firma.de

# Server
PORT=3001
